import platform     
import os
import sys

# =========================
# COMMAND REGISTRY
# =========================

commands = {}

def command(name):
    def decorator(func):
        commands[name] = func
        return func
    return decorator

# ========================
# COMMAND FUNCTIONS
# ========================

@command("info")
def sysrem_imfo():
    print(platform.system())
    print(platform.version())

@command("list")
def file_list():
    print(os.listdir("."))

@command("note")
def create_nore():
    note = input("Write your note")

    with open("notes.txt", "a") as f:
        f.write(note + "\n")

    print("note saved")

@command("read")
def read_notes():
    try:
        with open("notes.txt", "r") as f:
            print(f.read())

    except FileNotFoundError:
        print("No notes found")
    except Exception as e:
        print("Error:", e)

@command("help")
def help_menu():
    print("\nAvailable commands:")

    for cmd in commands:
        print(".", cmd)

    print("- exit")

# =====================
# INTERACTIVE MODE
# =====================

def interactive_mode():

    print("\nTool Kit Interactive Mode")
    print("Type 'help' for commands\n")

    while True:

        command_input = input("toolkit> ").strip().lower()

        if command_input == "exit":
             print("Exiting..")
             break

