           print("Unknown command")

# ====================
# MAIN ENTRY
# ===================

def main():

    # No command passed - interactive mode
    if len(sys.argv) < 2:
        interactive_mode()
        return

    # Command-line mode
    command_input = sys.agtv[1].lower()
    
    if command_input in commands:
        commands[command_input]()
    else:
        print("Unknown command")

# ==================
# PROGRAM START
# ==================


if __name__== "__main__":
    main()

